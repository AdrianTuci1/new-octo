{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Octomus Launcher Prototype",
  "version": "0.1.0",
  "identifier": "com.octomus.launcher.prototype",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Octomus Launcher Prototype",
        "width": 608,
        "height": 560,
        "resizable": false,
        "titleBarStyle": "Overlay",
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true
      },
      {
        "label": "settings",
        "create": false,
        "title": "Settings",
        "url": "index.html?panel=settings",
        "width": 1120,
        "height": 820,
        "minWidth": 920,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 24
        },
        "transparent": false,
        "shadow": true
      }
    ]
  }
}